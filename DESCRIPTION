Package: densityLP
Title: Local Polynomial Density Estimation on Complicated Domains
Version: 0.1.0
Authors@R: c(
    person("Karine",   "Bertin",       role = "aut",
           email = "karine.bertin@uv.cl",
           comment = c(ORCID = "0000-0002-8167-137X")),
    person("Nicolas",  "Klutchnikoff", role = c("aut", "cre"),
           email = "nicolas.klutchnikoff@univ-rennes2.fr",
           comment = c(ORCID = "0000-0001-9349-0771")),
    person("Frederic", "Ouimet",       role = "aut",
