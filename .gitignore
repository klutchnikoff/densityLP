# R package build artifacts
*.Rproj.user
*.Rhistory
*.RData
*.Ruserdata
.Rproj.user/

# R CMD check
/*.tar.gz
/*.Rcheck/

# Compiled C++ objects and shared library
src/*.o
src/*.so

# roxygen2-generated files: tracked in git (needed for install_github())
# Do not edit NAMESPACE or man/*.Rd by hand — run roxygen2::roxygenise()

# Air formatter cache
.air/

# Quarto rendered output (vignettes)
vignettes/*.html
vignettes/*_files/
vignettes/*_cache/

# testthat side-effects
tests/testthat/Rplots.pdf

# macOS
.DS_Store

# testthat snapshots (keep only intentional ones)
tests/testthat/_snaps/
README_files/
README.html
